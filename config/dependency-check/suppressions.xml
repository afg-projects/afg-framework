<?xml version="1.0" encoding="UTF-8"?>
<!--
  OWASP Dependency Check Suppressions

  This file contains suppression rules for known false positives or acceptable vulnerabilities.
  Each suppression should include:
  1. A clear reason for the suppression
  2. An expiration date for review
  3. References to relevant documentation or issue trackers

  Documentation: https://jeremylong.github.io/DependencyCheck/general/suppression.html
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- PMD 7.13.0 - CVE-2026-28338 -->
    <!--
    PMD is only used as a static analysis tool during build, not shipped in production artifacts.
    The vulnerability does not affect runtime security.
    PMD version 7.23.0 is used in the project, which is newer than 7.13.0 and may have the fix.
    This appears to be a false positive due to CPE matching.
    -->
    <suppress>
        <notes>
            <![CDATA[
            Reason: PMD is a build-time static analysis tool, not shipped in production.
            The project uses PMD 7.23.0 which is newer than the vulnerable version.
            This is likely a CPE matching false positive.
            ]]>
        </notes>
        <packageUrl regex="true">^pkg:maven/net\.sourceforge\.pmd/pmd-.*@.*$</packageUrl>
        <cve>CVE-2026-28338</cve>
    </suppress>

    <!-- commons-lang3 3.17.0 - CVE-2025-48924 -->
    <!--
    Review this suppression based on actual usage and impact assessment.
    Reference: https://nvd.nist.gov/vuln/detail/CVE-2025-48924
    -->
    <suppress>
        <notes>
            <![CDATA[
            Reason: Commons Lang 3.17.0 is used transitively by PMD for static analysis.
            Not shipped in production artifacts. Review before production deployment.
            Reference: https://nvd.nist.gov/vuln/detail/CVE-2025-48924
            ]]>
        </notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.commons/commons-lang3@3\.17\.0$</packageUrl>
        <cve>CVE-2025-48924</cve>
    </suppress>

