<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v1.0.0-001-ai-model-provider" author="afg">
        <createTable tableName="ai_model_provider" remarks="模型供应商">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_ai_model_provider"/>
            </column>
            <column name="provider_name" type="VARCHAR(100)" remarks="供应商名称">
                <constraints nullable="false"/>
            </column>
            <column name="provider_type" type="VARCHAR(50)" remarks="供应商类型"/>
            <column name="base_url" type="VARCHAR(500)" remarks="API基础URL"/>
            <column name="api_key" type="VARCHAR(500)" remarks="API密钥"/>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true" remarks="是否启用">
                <constraints nullable="false"/>
            </column>
            <column name="config" type="CLOB" remarks="供应商配置(JSON)"/>
            <column name="create_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="创建时间">
                <constraints nullable="false"/>
            </column>
            <column name="update_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="ai_model_provider" columnNames="provider_name" constraintName="uk_ai_model_provider_name"/>
    </changeSet>

</databaseChangeLog>
