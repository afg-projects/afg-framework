<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v1.0.0-009-ai-workflow-execution" author="afg">
        <createTable tableName="ai_workflow_execution" remarks="工作流执行">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_ai_workflow_execution"/>
            </column>
            <column name="workflow_definition_id" type="BIGINT" remarks="工作流定义ID">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)" remarks="状态">
                <constraints nullable="false"/>
            </column>
            <column name="input" type="CLOB" remarks="输入(JSON)"/>
            <column name="output" type="CLOB" remarks="输出(JSON)"/>
            <column name="error" type="CLOB" remarks="错误信息"/>
            <column name="duration_ms" type="BIGINT" remarks="耗时(毫秒)"/>
            <column name="user_id" type="VARCHAR(100)" remarks="用户ID"/>
            <column name="create_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="创建时间">
                <constraints nullable="false"/>
            </column>
            <column name="update_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="ai_workflow_execution" indexName="idx_ai_workflow_exec_status">
            <column name="status"/>
        </createIndex>

        <createIndex tableName="ai_workflow_execution" indexName="idx_ai_workflow_exec_time">
            <column name="create_time"/>
        </createIndex>

        <addForeignKeyConstraint baseTableName="ai_workflow_execution" baseColumnNames="workflow_definition_id"
                                 constraintName="fk_ai_workflow_exec_def"
                                 referencedTableName="ai_workflow_definition" referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
