<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v1.0.0-006-ai-agent-definition" author="afg">
        <createTable tableName="ai_agent_definition" remarks="Agent定义">
            <column name="id" type="VARCHAR(32)">
                <constraints primaryKey="true" primaryKeyName="pk_ai_agent_definition"/>
            </column>
            <column name="name" type="VARCHAR(200)" remarks="名称">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(1000)" remarks="描述"/>
            <column name="system_prompt" type="CLOB" remarks="系统提示词"/>
            <column name="chat_client_name" type="VARCHAR(100)" remarks="ChatClient名称"/>
            <column name="model_name" type="VARCHAR(200)" remarks="模型名称"/>
            <column name="temperature" type="DOUBLE" remarks="温度参数"/>
            <column name="max_tokens" type="INT" remarks="最大Token数"/>
            <column name="max_iterations" type="INT" defaultValueNumeric="10" remarks="最大迭代次数"/>
            <column name="knowledge_base_ids" type="CLOB" remarks="知识库ID列表(JSON)"/>
            <column name="tool_ids" type="CLOB" remarks="工具ID列表(JSON)"/>
            <column name="config" type="CLOB" remarks="配置(JSON)"/>
            <column name="user_id" type="VARCHAR(64)" remarks="用户ID"/>
            <column name="tenant_id" type="VARCHAR(64)" remarks="租户ID"/>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false" remarks="删除标记">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="创建时间">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="ai_agent_definition" columnNames="name" constraintName="uk_ai_agent_def_name"/>
    </changeSet>

</databaseChangeLog>
