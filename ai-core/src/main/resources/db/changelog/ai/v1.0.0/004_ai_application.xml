<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v1.0.0-004-ai-application" author="afg">
        <createTable tableName="ai_application" remarks="AI应用">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_ai_application"/>
            </column>
            <column name="name" type="VARCHAR(200)" remarks="应用名称">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(1000)" remarks="描述"/>
            <column name="type" type="VARCHAR(50)" remarks="类型(SIMPLE/WORKFLOW)">
                <constraints nullable="false"/>
            </column>
            <column name="access_token" type="VARCHAR(200)" remarks="访问令牌"/>
            <column name="status" type="VARCHAR(50)" defaultValue="DRAFT" remarks="状态">
                <constraints nullable="false"/>
            </column>
            <column name="config" type="CLOB" remarks="配置(JSON)"/>
            <column name="icon" type="VARCHAR(500)" remarks="图标"/>
            <column name="sort" type="INT" defaultValueNumeric="0" remarks="排序"/>
            <column name="user_id" type="VARCHAR(64)" remarks="用户ID"/>
            <column name="tenant_id" type="VARCHAR(64)" remarks="租户ID"/>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false" remarks="删除标记">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="创建时间">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="ai_application" columnNames="name" constraintName="uk_ai_application_name"/>

        <createIndex tableName="ai_application" indexName="idx_ai_application_token">
            <column name="access_token"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
