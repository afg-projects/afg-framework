<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v1.0.0-016-ai-tool-registry" author="afg">
        <createTable tableName="ai_tool_registry" remarks="工具注册">
            <column name="id" type="VARCHAR(32)">
                <constraints primaryKey="true" primaryKeyName="pk_ai_tool_registry"/>
            </column>
            <column name="name" type="VARCHAR(200)" remarks="名称">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(1000)" remarks="描述"/>
            <column name="type" type="VARCHAR(50)" remarks="类型(FUNCTION/MCP/SERVICE)">
                <constraints nullable="false"/>
            </column>
            <column name="endpoint" type="VARCHAR(500)" remarks="端点"/>
            <column name="parameters" type="CLOB" remarks="参数(JSON)"/>
            <column name="config" type="CLOB" remarks="配置(JSON)"/>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true" remarks="是否启用">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="VARCHAR(64)" remarks="用户ID"/>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false" remarks="删除标记">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="创建时间">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="ai_tool_registry" columnNames="name" constraintName="uk_ai_tool_registry_name"/>
    </changeSet>

</databaseChangeLog>
