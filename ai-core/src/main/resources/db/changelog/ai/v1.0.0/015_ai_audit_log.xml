<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v1.0.0-015-ai-audit-log" author="afg">
        <createTable tableName="ai_audit_log" remarks="审计日志">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_ai_audit_log"/>
            </column>
            <column name="operation" type="VARCHAR(100)" remarks="操作">
                <constraints nullable="false"/>
            </column>
            <column name="method" type="VARCHAR(200)" remarks="方法"/>
            <column name="user_id" type="VARCHAR(100)" remarks="用户ID"/>
            <column name="input" type="CLOB" remarks="输入(JSON)"/>
            <column name="output" type="CLOB" remarks="输出(JSON)"/>
            <column name="duration_ms" type="BIGINT" remarks="耗时(毫秒)"/>
            <column name="error" type="CLOB" remarks="错误信息"/>
            <column name="level" type="VARCHAR(50)" remarks="级别"/>
            <column name="metadata" type="CLOB" remarks="元数据(JSON)"/>
            <column name="create_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="创建时间">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="ai_audit_log" indexName="idx_ai_audit_log_op">
            <column name="operation"/>
        </createIndex>

        <createIndex tableName="ai_audit_log" indexName="idx_ai_audit_log_user">
            <column name="user_id"/>
        </createIndex>

        <createIndex tableName="ai_audit_log" indexName="idx_ai_audit_log_time">
            <column name="create_time"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
