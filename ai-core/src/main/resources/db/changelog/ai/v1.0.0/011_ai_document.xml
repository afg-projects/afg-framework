<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v1.0.0-011-ai-document" author="afg">
        <createTable tableName="ai_document" remarks="文档">
            <column name="id" type="VARCHAR(32)">
                <constraints primaryKey="true" primaryKeyName="pk_ai_document"/>
            </column>
            <column name="knowledge_base_id" type="VARCHAR(32)" remarks="知识库ID">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(500)" remarks="标题">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="CLOB" remarks="内容"/>
            <column name="source_url" type="VARCHAR(500)" remarks="来源URL"/>
            <column name="file_type" type="VARCHAR(50)" remarks="文件类型"/>
            <column name="file_size" type="BIGINT" remarks="文件大小"/>
            <column name="status" type="VARCHAR(50)" defaultValue="PENDING" remarks="状态">
                <constraints nullable="false"/>
            </column>
            <column name="error" type="CLOB" remarks="错误信息"/>
            <column name="chunk_count" type="INT" defaultValueNumeric="0" remarks="分块数量"/>
            <column name="metadata" type="CLOB" remarks="元数据(JSON)"/>
            <column name="tenant_id" type="VARCHAR(64)" remarks="租户ID"/>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false" remarks="删除标记">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="创建时间">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="ai_document" indexName="idx_ai_document_kb">
            <column name="knowledge_base_id"/>
        </createIndex>

        <createIndex tableName="ai_document" indexName="idx_ai_document_status">
            <column name="status"/>
        </createIndex>

        <addForeignKeyConstraint baseTableName="ai_document" baseColumnNames="knowledge_base_id"
                                 constraintName="fk_ai_document_kb"
                                 referencedTableName="ai_knowledge_base" referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
