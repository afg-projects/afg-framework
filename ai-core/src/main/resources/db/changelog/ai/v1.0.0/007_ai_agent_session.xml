<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v1.0.0-007-ai-agent-session" author="afg">
        <createTable tableName="ai_agent_session" remarks="Agent会话">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_ai_agent_session"/>
            </column>
            <column name="agent_definition_id" type="BIGINT" remarks="Agent定义ID">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="VARCHAR(64)" remarks="用户ID"/>
            <column name="title" type="VARCHAR(500)" remarks="标题"/>
            <column name="status" type="VARCHAR(50)" defaultValue="ACTIVE" remarks="状态">
                <constraints nullable="false"/>
            </column>
            <column name="metadata" type="CLOB" remarks="元数据(JSON)"/>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false" remarks="删除标记">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="创建时间">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="ai_agent_session" indexName="idx_ai_agent_session_user">
            <column name="user_id"/>
        </createIndex>

        <addForeignKeyConstraint baseTableName="ai_agent_session" baseColumnNames="agent_definition_id"
                                 constraintName="fk_ai_agent_session_def"
                                 referencedTableName="ai_agent_definition" referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
