<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v1.0.0-003-ai-model-usage" author="afg">
        <createTable tableName="ai_model_usage" remarks="模型使用记录">
            <column name="id" type="VARCHAR(32)">
                <constraints primaryKey="true" primaryKeyName="pk_ai_model_usage"/>
            </column>
            <column name="model_config_id" type="VARCHAR(32)" remarks="模型配置ID">
                <constraints nullable="false"/>
            </column>
            <column name="application_id" type="VARCHAR(32)" remarks="应用ID"/>
            <column name="user_id" type="VARCHAR(64)" remarks="用户ID"/>
            <column name="input_tokens" type="BIGINT" defaultValueNumeric="0" remarks="输入Token数"/>
            <column name="output_tokens" type="BIGINT" defaultValueNumeric="0" remarks="输出Token数"/>
            <column name="total_tokens" type="BIGINT" defaultValueNumeric="0" remarks="总Token数"/>
            <column name="cost" type="DECIMAL(19,6)" defaultValueNumeric="0" remarks="费用"/>
            <column name="duration_ms" type="BIGINT" remarks="耗时(毫秒)"/>
            <column name="status" type="VARCHAR(50)" remarks="状态"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="创建时间">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="ai_model_usage" indexName="idx_ai_model_usage_config">
            <column name="model_config_id"/>
        </createIndex>

        <createIndex tableName="ai_model_usage" indexName="idx_ai_model_usage_app">
            <column name="application_id"/>
        </createIndex>

        <createIndex tableName="ai_model_usage" indexName="idx_ai_model_usage_time">
            <column name="created_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
