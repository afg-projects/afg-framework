<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v1.0.0-002-ai-model-config" author="afg">
        <createTable tableName="ai_model_config" remarks="模型配置">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_ai_model_config"/>
            </column>
            <column name="provider_id" type="BIGINT" remarks="供应商ID">
                <constraints nullable="false"/>
            </column>
            <column name="model_name" type="VARCHAR(100)" remarks="模型名称">
                <constraints nullable="false"/>
            </column>
            <column name="display_name" type="VARCHAR(200)" remarks="显示名称"/>
            <column name="model_type" type="VARCHAR(50)" remarks="模型类型(CHAT/EMBEDDING/IMAGE)">
                <constraints nullable="false"/>
            </column>
            <column name="capabilities" type="CLOB" remarks="模型能力(JSON)"/>
            <column name="config" type="CLOB" remarks="模型配置(JSON)"/>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true" remarks="是否启用">
                <constraints nullable="false"/>
            </column>
            <column name="create_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="创建时间">
                <constraints nullable="false"/>
            </column>
            <column name="update_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="ai_model_config" columnNames="provider_id, model_name" constraintName="uk_ai_model_config_name"/>

        <createIndex tableName="ai_model_config" indexName="idx_ai_model_config_type">
            <column name="model_type"/>
        </createIndex>

        <addForeignKeyConstraint baseTableName="ai_model_config" baseColumnNames="provider_id"
                                 constraintName="fk_ai_model_config_provider"
                                 referencedTableName="ai_model_provider" referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
