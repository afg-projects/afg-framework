<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v1.0.0-005-ai-application-version" author="afg">
        <createTable tableName="ai_application_version" remarks="应用版本">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_ai_application_version"/>
            </column>
            <column name="application_id" type="BIGINT" remarks="应用ID">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="VARCHAR(50)" remarks="版本号">
                <constraints nullable="false"/>
            </column>
            <column name="config" type="CLOB" remarks="配置(JSON)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(1000)" remarks="描述"/>
            <column name="published_at" type="TIMESTAMP" remarks="发布时间"/>
            <column name="user_id" type="VARCHAR(64)" remarks="用户ID"/>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false" remarks="删除标记">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="创建时间">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="ai_application_version" columnNames="application_id, version" constraintName="uk_ai_app_version"/>

        <addForeignKeyConstraint baseTableName="ai_application_version" baseColumnNames="application_id"
                                 constraintName="fk_ai_app_version_app"
                                 referencedTableName="ai_application" referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
