    <!-- ai_document_chunk: id BIGINT AUTO_INCREMENT -> VARCHAR(32), document_id BIGINT -> VARCHAR(32), knowledge_base_id BIGINT -> VARCHAR(32)
         Must drop/recreate foreign keys that reference ai_document(id) and ai_knowledge_base(id) -->
    <changeSet id="v1.1.0-012-ai-document-chunk" author="afg">
        <dropForeignKeyConstraint baseTableName="ai_document_chunk" constraintName="fk_ai_doc_chunk_doc"/>
        <dropForeignKeyConstraint baseTableName="ai_document_chunk" constraintName="fk_ai_doc_chunk_kb"/>
        <modifyDataType tableName="ai_document_chunk" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="ai_document_chunk" columnName="document_id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="ai_document_chunk" columnName="knowledge_base_id" newDataType="VARCHAR(32)"/>
        <addForeignKeyConstraint baseTableName="ai_document_chunk" baseColumnNames="document_id"
                                 constraintName="fk_ai_doc_chunk_doc"
                                 referencedTableName="ai_document" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="ai_document_chunk" baseColumnNames="knowledge_base_id"
                                 constraintName="fk_ai_doc_chunk_kb"
