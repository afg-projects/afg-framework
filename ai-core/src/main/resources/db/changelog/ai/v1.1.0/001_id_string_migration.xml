         Must drop/recreate foreign key that references ai_application(id) -->
    <changeSet id="v1.1.0-005-ai-application-version" author="afg">
        <dropForeignKeyConstraint baseTableName="ai_application_version" constraintName="fk_ai_app_version_app"/>
        <modifyDataType tableName="ai_application_version" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="ai_application_version" columnName="application_id" newDataType="VARCHAR(32)"/>
        <addForeignKeyConstraint baseTableName="ai_application_version" baseColumnNames="application_id"
                                 constraintName="fk_ai_app_version_app"
                                 referencedTableName="ai_application" referencedColumnNames="id"/>
    </changeSet>

