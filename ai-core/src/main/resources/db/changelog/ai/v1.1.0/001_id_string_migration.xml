<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ai_model_provider: id BIGINT AUTO_INCREMENT -> VARCHAR(32) -->
    <changeSet id="v1.1.0-001-ai-model-provider" author="afg">
        <modifyDataType tableName="ai_model_provider" columnName="id" newDataType="VARCHAR(32)"/>
    </changeSet>

    <!-- ai_model_config: id BIGINT AUTO_INCREMENT -> VARCHAR(32), provider_id BIGINT -> VARCHAR(32)
         Must drop/recreate foreign key that references ai_model_provider(id) -->
    <changeSet id="v1.1.0-002-ai-model-config" author="afg">
        <dropForeignKeyConstraint baseTableName="ai_model_config" constraintName="fk_ai_model_config_provider"/>
        <modifyDataType tableName="ai_model_config" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="ai_model_config" columnName="provider_id" newDataType="VARCHAR(32)"/>
        <addForeignKeyConstraint baseTableName="ai_model_config" baseColumnNames="provider_id"
                                 constraintName="fk_ai_model_config_provider"
                                 referencedTableName="ai_model_provider" referencedColumnNames="id"/>
    </changeSet>

    <!-- ai_model_usage: id BIGINT AUTO_INCREMENT -> VARCHAR(32), model_config_id BIGINT -> VARCHAR(32), application_id BIGINT -> VARCHAR(32) -->
    <changeSet id="v1.1.0-003-ai-model-usage" author="afg">
