<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd">

    <changeSet id="v1.0.0-004-sec-user-data-scope" author="afg">
        <createTable tableName="sec_user_data_scope" remarks="用户数据范围关联表">
            <column name="id" type="VARCHAR(32)">
                <constraints primaryKey="true" primaryKeyName="pk_sec_user_data_scope"/>
            </column>
            <column name="user_id" type="VARCHAR(100)" remarks="用户ID">
                <constraints nullable="false"/>
            </column>
            <column name="data_scope_id" type="VARCHAR(32)" remarks="数据范围ID">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)" remarks="租户ID"/>
            <column name="created_at" type="TIMESTAMP" defaultValueDate="CURRENT_TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueDate="CURRENT_TIMESTAMP" remarks="更新时间"/>
        </createTable>

        <addUniqueConstraint tableName="sec_user_data_scope" columnNames="user_id,data_scope_id,tenant_id"
                             constraintName="uk_sec_user_data_scope"/>
        <createIndex tableName="sec_user_data_scope" indexName="idx_sec_user_data_scope_user">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="sec_user_data_scope" indexName="idx_sec_user_data_scope_scope">
            <column name="data_scope_id"/>
        </createIndex>
        <createIndex tableName="sec_user_data_scope" indexName="idx_sec_user_data_scope_tenant">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>