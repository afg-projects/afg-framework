<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- sec_dept: id BIGINT AUTO_INCREMENT -> VARCHAR(32), parent_id BIGINT -> VARCHAR(32) -->
    <changeSet id="v1.1.0-001-sec-dept" author="afg">
        <modifyDataType tableName="sec_dept" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="sec_dept" columnName="parent_id" newDataType="VARCHAR(32)"/>
    </changeSet>

    <!-- sec_data_scope: id BIGINT AUTO_INCREMENT -> VARCHAR(32) -->
    <changeSet id="v1.1.0-002-sec-data-scope" author="afg">
        <modifyDataType tableName="sec_data_scope" columnName="id" newDataType="VARCHAR(32)"/>
    </changeSet>

    <!-- sec_user_dept: id BIGINT AUTO_INCREMENT -> VARCHAR(32), dept_id BIGINT -> VARCHAR(32), add updated_at -->
    <changeSet id="v1.1.0-003-sec-user-dept" author="afg">
        <modifyDataType tableName="sec_user_dept" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="sec_user_dept" columnName="dept_id" newDataType="VARCHAR(32)"/>
        <addColumn tableName="sec_user_dept">
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间"/>
        </addColumn>
    </changeSet>

    <!-- sec_user_data_scope: id BIGINT AUTO_INCREMENT -> VARCHAR(32), data_scope_id BIGINT -> VARCHAR(32), add updated_at -->
    <changeSet id="v1.1.0-004-sec-user-data-scope" author="afg">
        <modifyDataType tableName="sec_user_data_scope" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="sec_user_data_scope" columnName="data_scope_id" newDataType="VARCHAR(32)"/>
        <addColumn tableName="sec_user_data_scope">
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
