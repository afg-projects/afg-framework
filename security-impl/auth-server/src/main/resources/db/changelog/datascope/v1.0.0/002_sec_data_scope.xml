<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-002-sec-data-scope" author="afg">
        <createTable tableName="sec_data_scope" remarks="数据范围定义表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_sec_data_scope"/>
            </column>
            <column name="scope_code" type="VARCHAR(50)" remarks="范围编码">
                <constraints nullable="false"/>
            </column>
            <column name="scope_name" type="VARCHAR(100)" remarks="范围名称">
                <constraints nullable="false"/>
            </column>
            <column name="scope_type" type="VARCHAR(20)" remarks="范围类型：ALL/DEPT/DEPT_AND_CHILD/SELF/CUSTOM">
                <constraints nullable="false"/>
            </column>
            <column name="resource_code" type="VARCHAR(100)" remarks="资源编码"/>
            <column name="tenant_id" type="VARCHAR(50)" remarks="租户ID"/>
            <column name="created_at" type="TIMESTAMP" defaultValueDate="CURRENT_TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueDate="CURRENT_TIMESTAMP" remarks="更新时间"/>
        </createTable>

        <addUniqueConstraint tableName="sec_data_scope" columnNames="scope_code,tenant_id"
                             constraintName="uk_sec_data_scope_code"/>
        <createIndex tableName="sec_data_scope" indexName="idx_sec_data_scope_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="sec_data_scope" indexName="idx_sec_data_scope_type">
            <column name="scope_type"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>