<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="auth-login-log" author="afg">
        <createTable tableName="auth_login_log" remarks="登录日志表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_auth_login_log"/>
            </column>
            <column name="user_id" type="VARCHAR(50)" remarks="用户ID"/>
            <column name="username" type="VARCHAR(100)" remarks="用户名"/>
            <column name="tenant_id" type="VARCHAR(50)" remarks="租户ID"/>
            <column name="ip" type="VARCHAR(50)" remarks="IP地址"/>
            <column name="device_id" type="VARCHAR(100)" remarks="设备ID"/>
            <column name="device_name" type="VARCHAR(200)" remarks="设备名称"/>
            <column name="browser" type="VARCHAR(100)" remarks="浏览器"/>
            <column name="os" type="VARCHAR(100)" remarks="操作系统"/>
            <column name="location" type="VARCHAR(200)" remarks="登录地点"/>
            <column name="result" type="VARCHAR(20)" remarks="登录结果">
                <constraints nullable="false"/>
            </column>
            <column name="fail_reason" type="VARCHAR(200)" remarks="失败原因"/>
            <column name="login_time" type="TIMESTAMP" remarks="登录时间">
                <constraints nullable="false"/>
            </column>
            <column name="logout_time" type="TIMESTAMP" remarks="登出时间"/>
        </createTable>

        <createIndex indexName="idx_login_log_user" tableName="auth_login_log">
            <column name="user_id"/>
        </createIndex>

        <createIndex indexName="idx_login_log_time" tableName="auth_login_log">
            <column name="login_time"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
