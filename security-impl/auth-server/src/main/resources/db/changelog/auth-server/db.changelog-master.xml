<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <!-- Phase 1: 基础登录功能 -->
    <include file="auth-refresh-token.xml" relativeToChangelogFile="true"/>
    <include file="auth-token-blacklist.xml" relativeToChangelogFile="true"/>
    <include file="auth-captcha.xml" relativeToChangelogFile="true"/>

    <!-- Phase 2: 安全策略 -->
    <include file="auth-login-failure.xml" relativeToChangelogFile="true"/>
    <include file="auth-user-device.xml" relativeToChangelogFile="true"/>

    <!-- Phase 3: OAuth2 授权服务器 -->
    <include file="auth-client.xml" relativeToChangelogFile="true"/>

    <!-- Phase 4: 权限引擎 -->
    <include file="auth-user-role.xml" relativeToChangelogFile="true"/>
    <include file="auth-role-permission.xml" relativeToChangelogFile="true"/>
    <include file="auth-data-scope.xml" relativeToChangelogFile="true"/>

    <!-- Phase 5: 审计日志 -->
    <include file="auth-login-log.xml" relativeToChangelogFile="true"/>
    <include file="auth-security-event.xml" relativeToChangelogFile="true"/>

</databaseChangeLog>
