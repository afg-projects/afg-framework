<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="auth-client" author="afg">
        <createTable tableName="auth_client" remarks="OAuth2客户端表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_auth_client"/>
            </column>
            <column name="client_id" type="VARCHAR(100)" remarks="客户端ID">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_client_id"/>
            </column>
            <column name="client_secret" type="VARCHAR(255)" remarks="客户端密钥"/>
            <column name="client_name" type="VARCHAR(200)" remarks="客户端名称">
                <constraints nullable="false"/>
            </column>
            <column name="redirect_uris" type="TEXT" remarks="重定向URI列表"/>
            <column name="scopes" type="VARCHAR(500)" remarks="授权范围"/>
            <column name="grant_types" type="VARCHAR(200)" remarks="授权类型"/>
            <column name="require_pkce" type="BOOLEAN" remarks="是否需要PKCE" defaultValueBoolean="false"/>
            <column name="access_token_ttl" type="BIGINT" remarks="访问令牌TTL" defaultValueNumeric="7200"/>
            <column name="refresh_token_ttl" type="BIGINT" remarks="刷新令牌TTL" defaultValueNumeric="604800"/>
            <column name="status" type="SMALLINT" remarks="状态" defaultValueNumeric="1"/>
            <column name="created_at" type="TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" remarks="更新时间"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
