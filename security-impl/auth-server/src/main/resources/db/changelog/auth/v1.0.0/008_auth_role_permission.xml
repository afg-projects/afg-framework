<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="v1.0.0-008-auth-role-permission" author="afg">
        <createTable tableName="auth_role_permission" remarks="角色权限关联表">
            <column name="id" type="VARCHAR(32)">
                <constraints primaryKey="true" primaryKeyName="pk_auth_role_permission"/>
            </column>
            <column name="role_id" type="VARCHAR(50)" remarks="角色ID">
                <constraints nullable="false"/>
            </column>
            <column name="permission" type="VARCHAR(100)" remarks="权限标识">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)" remarks="租户ID"/>
            <column name="created_at" type="TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" remarks="更新时间"/>
        </createTable>

        <createIndex indexName="uk_role_perm_tenant" tableName="auth_role_permission" unique="true">
            <column name="role_id"/>
            <column name="permission"/>
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>