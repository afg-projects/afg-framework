<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-005-auth-user-device" author="afg">
        <createTable tableName="auth_user_device" remarks="用户设备表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_auth_user_device"/>
            </column>
            <column name="user_id" type="VARCHAR(50)" remarks="用户ID">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)" remarks="租户ID"/>
            <column name="device_id" type="VARCHAR(100)" remarks="设备ID">
                <constraints nullable="false"/>
            </column>
            <column name="device_name" type="VARCHAR(200)" remarks="设备名称"/>
            <column name="device_type" type="VARCHAR(50)" remarks="设备类型"/>
            <column name="last_login_ip" type="VARCHAR(50)" remarks="最后登录IP"/>
            <column name="last_login_time" type="TIMESTAMP" remarks="最后登录时间"/>
            <column name="status" type="SMALLINT" remarks="状态" defaultValueNumeric="1"/>
            <column name="created_at" type="TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" remarks="更新时间"/>
        </createTable>

        <createIndex indexName="uk_user_device" tableName="auth_user_device" unique="true">
            <column name="user_id"/>
            <column name="device_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>