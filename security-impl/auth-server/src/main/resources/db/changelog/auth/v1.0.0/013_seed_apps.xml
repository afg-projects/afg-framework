<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd">

    <changeSet id="v1.0.0-013-seed-apps" author="afg">

        <!-- 清理旧的 keystone/identity/governance 客户端（合并后不再需要） -->
        <delete tableName="auth_client">
            <where>client_id IN ('afg-keystone-ui', 'afg-identity-ui', 'afg-governance-ui')</where>
        </delete>

        <!-- 清理旧的应用记录（keystone/identity/governance 已合并为系统管理） -->
        <delete tableName="auth_app">
            <where>name IN ('Keystone', 'Identity', '身份管理', '治理中心', '系统管理', 'AI 平台')</where>
        </delete>

        <!-- OAuth2 客户端：工作台 -->
        <insert tableName="auth_client">
            <column name="id" value="1894567890000000001"/>
            <column name="client_id" value="afg-workspace-ui"/>
            <column name="client_name" value="工作台前端"/>
            <column name="redirect_uris" value="http://localhost:8000/sso/callback"/>
            <column name="scopes" value="read,write"/>
            <column name="grant_types" value="authorization_code,refresh_token"/>
            <column name="require_pkce" valueBoolean="true"/>
            <column name="access_token_ttl" valueNumeric="7200"/>
            <column name="refresh_token_ttl" valueNumeric="604800"/>
            <column name="status" valueNumeric="1"/>
        </insert>

        <!-- OAuth2 客户端：系统管理 -->
        <insert tableName="auth_client">
            <column name="id" value="1894567890000000002"/>
            <column name="client_id" value="afg-platform-ui"/>
            <column name="client_name" value="系统管理前端"/>
            <column name="redirect_uris" value="http://localhost:3001/platform-ui/sso/callback"/>
            <column name="scopes" value="read,write"/>
            <column name="grant_types" value="authorization_code,refresh_token"/>
            <column name="require_pkce" valueBoolean="true"/>
            <column name="access_token_ttl" valueNumeric="7200"/>
            <column name="refresh_token_ttl" valueNumeric="604800"/>
            <column name="status" valueNumeric="1"/>
        </insert>

        <!-- OAuth2 客户端：AI 平台 -->
        <insert tableName="auth_client">
            <column name="id" value="1894567890000000003"/>
            <column name="client_id" value="afg-ai-ui"/>
            <column name="client_name" value="AI 平台前端"/>
            <column name="redirect_uris" value="http://localhost:3002/ai-ui/sso/callback"/>
            <column name="scopes" value="read,write"/>
            <column name="grant_types" value="authorization_code,refresh_token"/>
            <column name="require_pkce" valueBoolean="true"/>
            <column name="access_token_ttl" valueNumeric="7200"/>
            <column name="refresh_token_ttl" valueNumeric="604800"/>
            <column name="status" valueNumeric="1"/>
        </insert>

        <!-- 应用：系统管理 -->
        <insert tableName="auth_app">
            <column name="id" value="1894567890000000004"/>
            <column name="name" value="系统管理"/>
            <column name="logo" value="setting"/>
            <column name="description" value="身份管理、服务治理、配置管理"/>
            <column name="app_type" value="mf"/>
            <column name="status" valueNumeric="1"/>
            <column name="sort_order" valueNumeric="1"/>
            <column name="active_rule" value="/platform-ui"/>
            <column name="entry_url" value="http://localhost:3001/platform-ui/remoteEntry.js"/>
            <column name="export_path" value="./export-app"/>
            <column name="allowed_origins" value="http://localhost:3001"/>
            <column name="client_id" value="afg-platform-ui"/>
        </insert>

        <!-- 应用：AI 平台 -->
        <insert tableName="auth_app">
            <column name="id" value="1894567890000000005"/>
            <column name="name" value="AI 平台"/>
            <column name="logo" value="robot"/>
            <column name="description" value="AI 对话、技能、知识库管理"/>
            <column name="app_type" value="mf"/>
            <column name="status" valueNumeric="1"/>
            <column name="sort_order" valueNumeric="2"/>
            <column name="active_rule" value="/ai-ui"/>
            <column name="entry_url" value="http://localhost:3002/ai-ui/remoteEntry.js"/>
            <column name="export_path" value="./export-app"/>
            <column name="allowed_origins" value="http://localhost:3002"/>
            <column name="client_id" value="afg-ai-ui"/>
        </insert>

        <rollback>
            <delete tableName="auth_app">
                <where>name IN ('系统管理', 'AI 平台')</where>
            </delete>
            <delete tableName="auth_client">
                <where>client_id IN ('afg-workspace-ui', 'afg-platform-ui', 'afg-ai-ui')</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
