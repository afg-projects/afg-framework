<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-012-auth-app" author="afg">
        <createTable tableName="auth_app" remarks="应用管理表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_auth_app"/>
            </column>
            <column name="name" type="VARCHAR(100)" remarks="应用名称">
                <constraints nullable="false"/>
            </column>
            <column name="logo" type="VARCHAR(500)" remarks="应用Logo URL"/>
            <column name="description" type="VARCHAR(500)" remarks="应用描述"/>
            <column name="app_type" type="VARCHAR(20)" remarks="应用类型: mf/wujie/standalone/api" defaultValue="mf">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="SMALLINT" remarks="状态: 1启用/0停用" defaultValueNumeric="1"/>
            <column name="sort_order" type="INT" remarks="排序" defaultValueNumeric="0"/>

            <!-- 微前端配置 -->
            <column name="active_rule" type="VARCHAR(100)" remarks="路由前缀, 如 /identity"/>
            <column name="entry_url" type="VARCHAR(500)" remarks="MF模式: remoteEntry.js URL"/>
            <column name="export_path" type="VARCHAR(100)" remarks="MF模式: 暴露模块路径"/>
            <column name="wujie_url" type="VARCHAR(500)" remarks="Wujie模式: 子应用完整URL"/>

            <!-- CORS 配置 -->
            <column name="allowed_origins" type="TEXT" remarks="CORS允许的来源, 逗号分隔"/>

            <!-- OAuth2 客户端关联 -->
            <column name="client_id" type="VARCHAR(100)" remarks="关联的OAuth2客户端ID"/>

            <!-- 多租户 -->
            <column name="tenant_id" type="VARCHAR(50)" remarks="租户ID, NULL=全局应用"/>

            <!-- 审计 -->
            <column name="created_at" type="TIMESTAMP" remarks="创建时间" defaultValueDate="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" remarks="更新时间" defaultValueDate="CURRENT_TIMESTAMP"/>
        </createTable>

        <addUniqueConstraint tableName="auth_app" columnNames="name,tenant_id"
                             constraintName="uk_auth_app_name"/>

        <createIndex indexName="idx_auth_app_tenant" tableName="auth_app">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_auth_app_client_id" tableName="auth_app">
            <column name="client_id"/>
        </createIndex>

        <createIndex indexName="idx_auth_app_status" tableName="auth_app">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
