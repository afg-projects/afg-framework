<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-002-sec-permission" author="afg">
        <createTable tableName="sec_permission" remarks="权限表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_sec_permission"/>
            </column>
            <column name="permission_code" type="VARCHAR(100)" remarks="权限编码">
                <constraints nullable="false"/>
            </column>
            <column name="permission_name" type="VARCHAR(100)" remarks="权限名称">
                <constraints nullable="false"/>
            </column>
            <column name="resource_id" type="BIGINT" remarks="资源ID"/>
            <column name="tenant_id" type="VARCHAR(50)" remarks="租户ID"/>
            <column name="created_at" type="TIMESTAMP" defaultValueDate="CURRENT_TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueDate="CURRENT_TIMESTAMP" remarks="更新时间"/>
        </createTable>

        <addUniqueConstraint tableName="sec_permission" columnNames="permission_code,tenant_id"
                             constraintName="uk_sec_permission_code"/>
        <createIndex tableName="sec_permission" indexName="idx_sec_permission_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="sec_permission" indexName="idx_sec_permission_resource">
            <column name="resource_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>