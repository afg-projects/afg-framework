<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- sec_permission: resource_id BIGINT -> VARCHAR(32) -->
    <changeSet id="v1.1.0-001-sec-permission-resource-id" author="afg">
        <modifyDataType tableName="sec_permission" columnName="resource_id" newDataType="VARCHAR(32)"/>
    </changeSet>

    <!-- sec_role: id BIGINT AUTO_INCREMENT -> VARCHAR(32) -->
    <changeSet id="v1.1.0-002-sec-role-id" author="afg">
        <modifyDataType tableName="sec_role" columnName="id" newDataType="VARCHAR(32)"/>
    </changeSet>

    <!-- sec_role_permission: id BIGINT AUTO_INCREMENT -> VARCHAR(32), role_id/permission_id BIGINT -> VARCHAR(32), add updated_at -->
    <changeSet id="v1.1.0-003-sec-role-permission" author="afg">
        <modifyDataType tableName="sec_role_permission" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="sec_role_permission" columnName="role_id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="sec_role_permission" columnName="permission_id" newDataType="VARCHAR(32)"/>
        <addColumn tableName="sec_role_permission">
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间"/>
        </addColumn>
    </changeSet>

    <!-- sec_role_hierarchy: id BIGINT AUTO_INCREMENT -> VARCHAR(32), role_id/parent_role_id BIGINT -> VARCHAR(32), add updated_at -->
    <changeSet id="v1.1.0-004-sec-role-hierarchy" author="afg">
        <modifyDataType tableName="sec_role_hierarchy" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="sec_role_hierarchy" columnName="role_id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="sec_role_hierarchy" columnName="parent_role_id" newDataType="VARCHAR(32)"/>
        <addColumn tableName="sec_role_hierarchy">
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间"/>
        </addColumn>
    </changeSet>

    <!-- sec_user_role: id BIGINT AUTO_INCREMENT -> VARCHAR(32), role_id BIGINT -> VARCHAR(32), add updated_at -->
    <changeSet id="v1.1.0-005-sec-user-role" author="afg">
        <modifyDataType tableName="sec_user_role" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="sec_user_role" columnName="role_id" newDataType="VARCHAR(32)"/>
        <addColumn tableName="sec_user_role">
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间"/>
        </addColumn>
    </changeSet>

    <!-- sec_casbin_rule: id BIGINT AUTO_INCREMENT -> VARCHAR(32), add created_at/updated_at -->
    <changeSet id="v1.1.0-006-sec-casbin-rule" author="afg">
        <modifyDataType tableName="sec_casbin_rule" columnName="id" newDataType="VARCHAR(32)"/>
        <addColumn tableName="sec_casbin_rule">
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
