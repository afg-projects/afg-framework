<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd">

    <changeSet id="v1.0.0-005-sec-role-hierarchy" author="afg">
        <createTable tableName="sec_role_hierarchy" remarks="角色继承关系表">
            <column name="id" type="VARCHAR(32)">
                <constraints primaryKey="true" primaryKeyName="pk_sec_role_hierarchy"/>
            </column>
            <column name="role_id" type="VARCHAR(32)" remarks="角色ID">
                <constraints nullable="false"/>
            </column>
            <column name="parent_role_id" type="VARCHAR(32)" remarks="父角色ID">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)" remarks="租户ID"/>
            <column name="created_at" type="TIMESTAMP" defaultValueDate="CURRENT_TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueDate="CURRENT_TIMESTAMP" remarks="更新时间"/>
        </createTable>

        <addUniqueConstraint tableName="sec_role_hierarchy" columnNames="role_id,parent_role_id"
                             constraintName="uk_sec_role_hierarchy"/>
        <createIndex tableName="sec_role_hierarchy" indexName="idx_sec_role_hierarchy_role">
            <column name="role_id"/>
        </createIndex>
        <createIndex tableName="sec_role_hierarchy" indexName="idx_sec_role_hierarchy_parent">
            <column name="parent_role_id"/>
        </createIndex>
        <createIndex tableName="sec_role_hierarchy" indexName="idx_sec_role_hierarchy_tenant">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>