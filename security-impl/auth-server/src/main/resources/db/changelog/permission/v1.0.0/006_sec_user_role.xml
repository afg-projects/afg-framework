<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="v1.0.0-006-sec-user-role" author="afg">
        <createTable tableName="sec_user_role" remarks="用户角色关联表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_sec_user_role"/>
            </column>
            <column name="user_id" type="VARCHAR(100)" remarks="用户ID">
                <constraints nullable="false"/>
            </column>
            <column name="role_id" type="BIGINT" remarks="角色ID">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)" remarks="租户ID"/>
            <column name="created_at" type="TIMESTAMP" defaultValueDate="CURRENT_TIMESTAMP" remarks="创建时间"/>
        </createTable>

        <addUniqueConstraint tableName="sec_user_role" columnNames="user_id,role_id,tenant_id"
                             constraintName="uk_sec_user_role"/>
        <createIndex tableName="sec_user_role" indexName="idx_sec_user_role_user">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="sec_user_role" indexName="idx_sec_user_role_role">
            <column name="role_id"/>
        </createIndex>
        <createIndex tableName="sec_user_role" indexName="idx_sec_user_role_tenant">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>