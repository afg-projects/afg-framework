<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-003-sec-role" author="afg">
        <createTable tableName="sec_role" remarks="角色表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_sec_role"/>
            </column>
            <column name="role_code" type="VARCHAR(50)" remarks="角色编码">
                <constraints nullable="false"/>
            </column>
            <column name="role_name" type="VARCHAR(100)" remarks="角色名称">
                <constraints nullable="false"/>
            </column>
            <column name="role_type" type="VARCHAR(20)" defaultValue="CUSTOM" remarks="角色类型"/>
            <column name="tenant_id" type="VARCHAR(50)" remarks="租户ID"/>
            <column name="status" type="INT" defaultValueNumeric="1" remarks="状态：1-启用，0-禁用"/>
            <column name="sort_order" type="INT" defaultValueNumeric="0" remarks="排序号"/>
            <column name="description" type="VARCHAR(255)" remarks="描述"/>
            <column name="created_at" type="TIMESTAMP" defaultValueDate="CURRENT_TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueDate="CURRENT_TIMESTAMP" remarks="更新时间"/>
        </createTable>

        <addUniqueConstraint tableName="sec_role" columnNames="role_code,tenant_id"
                             constraintName="uk_sec_role_code"/>
        <createIndex tableName="sec_role" indexName="idx_sec_role_tenant">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>