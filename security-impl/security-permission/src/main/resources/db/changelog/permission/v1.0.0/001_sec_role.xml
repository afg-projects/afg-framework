<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-001-sec-role" author="afg">
        <createTable tableName="sec_role" remarks="角色表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_sec_role"/>
            </column>
            <column name="role_code" type="VARCHAR(50)" remarks="角色编码">
                <constraints nullable="false"/>
            </column>
            <column name="role_name" type="VARCHAR(100)" remarks="角色名称">
                <constraints nullable="false"/>
            </column>
            <column name="role_type" type="VARCHAR(20)" remarks="角色类型(DEFAULT/CUSTOM)" defaultValue="CUSTOM">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)" remarks="租户ID"/>
            <column name="status" type="SMALLINT" remarks="状态" defaultValueNumeric="1"/>
            <column name="sort_order" type="INT" remarks="排序" defaultValueNumeric="0"/>
            <column name="description" type="VARCHAR(255)" remarks="描述"/>
        </createTable>

        <createIndex indexName="uk_sec_role_tenant_code" tableName="sec_role" unique="true">
            <column name="tenant_id"/>
            <column name="role_code"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
