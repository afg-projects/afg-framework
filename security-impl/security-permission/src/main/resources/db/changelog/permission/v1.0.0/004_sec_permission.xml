<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-004-sec-permission" author="afg">
        <createTable tableName="sec_permission" remarks="权限表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_sec_permission"/>
            </column>
            <column name="permission_code" type="VARCHAR(100)" remarks="权限编码(如user:read)">
                <constraints nullable="false"/>
            </column>
            <column name="permission_name" type="VARCHAR(100)" remarks="权限名称">
                <constraints nullable="false"/>
            </column>
            <column name="resource_id" type="BIGINT" remarks="资源ID"/>
            <column name="tenant_id" type="VARCHAR(50)" remarks="租户ID"/>
        </createTable>

        <createIndex indexName="uk_sec_permission_tenant_code" tableName="sec_permission" unique="true">
            <column name="tenant_id"/>
            <column name="permission_code"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
