<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-003-sec-resource" author="afg">
        <createTable tableName="sec_resource" remarks="资源表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_sec_resource"/>
            </column>
            <column name="resource_code" type="VARCHAR(100)" remarks="资源编码">
                <constraints nullable="false"/>
            </column>
            <column name="resource_name" type="VARCHAR(100)" remarks="资源名称">
                <constraints nullable="false"/>
            </column>
            <column name="resource_type" type="VARCHAR(20)" remarks="资源类型(MENU/BUTTON/API/DATA)">
                <constraints nullable="false"/>
            </column>
            <column name="parent_id" type="BIGINT" remarks="父资源ID"/>
            <column name="tenant_id" type="VARCHAR(50)" remarks="租户ID"/>
            <column name="sort_order" type="INT" remarks="排序" defaultValueNumeric="0"/>
            <column name="status" type="SMALLINT" remarks="状态" defaultValueNumeric="1"/>
        </createTable>

        <createIndex indexName="uk_sec_resource_tenant_code" tableName="sec_resource" unique="true">
            <column name="tenant_id"/>
            <column name="resource_code"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
