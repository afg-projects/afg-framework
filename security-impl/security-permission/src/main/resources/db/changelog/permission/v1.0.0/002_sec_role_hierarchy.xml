<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-002-sec-role-hierarchy" author="afg">
        <createTable tableName="sec_role_hierarchy" remarks="角色继承关系表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_sec_role_hierarchy"/>
            </column>
            <column name="role_id" type="BIGINT" remarks="角色ID">
                <constraints nullable="false"/>
            </column>
            <column name="parent_role_id" type="BIGINT" remarks="父角色ID">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)" remarks="租户ID"/>
        </createTable>

        <createIndex indexName="uk_sec_role_hierarchy" tableName="sec_role_hierarchy" unique="true">
            <column name="role_id"/>
            <column name="parent_role_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
