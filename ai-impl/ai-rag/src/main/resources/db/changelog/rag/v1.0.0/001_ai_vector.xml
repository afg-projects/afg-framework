<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-001-ai-vector" author="afg">
        <createTable tableName="ai_vector" remarks="AI向量存储表">
            <column name="id" type="VARCHAR(255)" remarks="文档ID">
                <constraints primaryKey="true" primaryKeyName="pk_ai_vector"/>
            </column>
            <column name="content" type="TEXT" remarks="文档内容">
                <constraints nullable="false"/>
            </column>
            <column name="embedding" type="vector(768)" remarks="向量嵌入"/>
            <column name="metadata" type="JSONB" remarks="元数据"/>
            <column name="tenant_id" type="VARCHAR(255)" remarks="租户ID"/>
            <column name="user_id" type="VARCHAR(255)" remarks="用户ID"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()" remarks="创建时间"/>
        </createTable>

        <createIndex indexName="idx_ai_vector_tenant" tableName="ai_vector">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_ai_vector_user" tableName="ai_vector">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
