<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="v1.0.0-003-gov-config-value" author="afg">
        <createTable tableName="gov_config_value" remarks="配置值表">
            <column name="id" type="VARCHAR(32)">
                <constraints primaryKey="true" primaryKeyName="pk_config_value"/>
            </column>
            <column name="environment_id" type="VARCHAR(32)" remarks="环境ID"/>
            <column name="item_id" type="VARCHAR(32)" remarks="配置项ID">
                <constraints nullable="false"/>
            </column>
            <column name="config_value" type="TEXT" remarks="配置值"/>
            <column name="value_type" type="VARCHAR(20)" remarks="值类型"/>
            <column name="version" type="BIGINT" remarks="版本号" defaultValueNumeric="1"/>
            <column name="tenant_id" type="VARCHAR(64)" remarks="租户ID"/>
            <column name="created_at" type="TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" remarks="更新时间"/>
        </createTable>

        <createIndex indexName="idx_config_value_tenant" tableName="gov_config_value">
            <column name="tenant_id"/>
        </createIndex>
        <addUniqueConstraint tableName="gov_config_value" constraintName="uk_config_value_item"
                             columnNames="item_id"/>
    </changeSet>

</databaseChangeLog>