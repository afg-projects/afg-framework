<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- gov_config_group: id BIGINT AUTO_INCREMENT -> VARCHAR(32), environment_id BIGINT -> VARCHAR(32) -->
    <changeSet id="v1.1.0-001-gov-config-group" author="afg">
        <modifyDataType tableName="gov_config_group" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="gov_config_group" columnName="environment_id" newDataType="VARCHAR(32)"/>
    </changeSet>

    <!-- gov_config_item: id BIGINT AUTO_INCREMENT -> VARCHAR(32), group_id BIGINT -> VARCHAR(32) -->
    <changeSet id="v1.1.0-002-gov-config-item" author="afg">
        <modifyDataType tableName="gov_config_item" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="gov_config_item" columnName="group_id" newDataType="VARCHAR(32)"/>
    </changeSet>

    <!-- gov_config_value: id BIGINT AUTO_INCREMENT -> VARCHAR(32), environment_id BIGINT -> VARCHAR(32), item_id BIGINT -> VARCHAR(32) -->
    <changeSet id="v1.1.0-003-gov-config-value" author="afg">
        <modifyDataType tableName="gov_config_value" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="gov_config_value" columnName="environment_id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="gov_config_value" columnName="item_id" newDataType="VARCHAR(32)"/>
    </changeSet>

    <!-- gov_config_history: id BIGINT AUTO_INCREMENT -> VARCHAR(32), item_id BIGINT -> VARCHAR(32), operator_id BIGINT -> VARCHAR(32) -->
    <changeSet id="v1.1.0-004-gov-config-history" author="afg">
        <modifyDataType tableName="gov_config_history" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="gov_config_history" columnName="item_id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="gov_config_history" columnName="operator_id" newDataType="VARCHAR(32)"/>
    </changeSet>

    <!-- gov_config_snapshot: id BIGINT AUTO_INCREMENT -> VARCHAR(32), group_id BIGINT -> VARCHAR(32), creator_id BIGINT -> VARCHAR(32), add updated_at -->
    <changeSet id="v1.1.0-005-gov-config-snapshot" author="afg">
        <modifyDataType tableName="gov_config_snapshot" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="gov_config_snapshot" columnName="group_id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="gov_config_snapshot" columnName="creator_id" newDataType="VARCHAR(32)"/>
        <addColumn tableName="gov_config_snapshot">
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间"/>
        </addColumn>
    </changeSet>

    <!-- gov_environment: id BIGINT AUTO_INCREMENT -> VARCHAR(32) -->
    <changeSet id="v1.1.0-006-gov-environment" author="afg">
        <modifyDataType tableName="gov_environment" columnName="id" newDataType="VARCHAR(32)"/>
    </changeSet>

    <!-- gov_service_registry: id BIGINT AUTO_INCREMENT -> VARCHAR(32) -->
    <changeSet id="v1.1.0-007-gov-service-registry" author="afg">
        <modifyDataType tableName="gov_service_registry" columnName="id" newDataType="VARCHAR(32)"/>
    </changeSet>

    <!-- gov_service_instance: id BIGINT AUTO_INCREMENT -> VARCHAR(32), service_id BIGINT -> VARCHAR(32)
         Must drop/recreate foreign key that references gov_service_registry(id) -->
    <changeSet id="v1.1.0-008-gov-service-instance" author="afg">
        <dropForeignKeyConstraint baseTableName="gov_service_instance" constraintName="fk_service_instance_registry"/>
        <modifyDataType tableName="gov_service_instance" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="gov_service_instance" columnName="service_id" newDataType="VARCHAR(32)"/>
        <addForeignKeyConstraint baseTableName="gov_service_instance"
                                 baseColumnNames="service_id"
                                 constraintName="fk_service_instance_registry"
                                 referencedTableName="gov_service_registry"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>

    <!-- gov_gray_release: id BIGINT AUTO_INCREMENT -> VARCHAR(32), config_item_id BIGINT -> VARCHAR(32), environment_id BIGINT -> VARCHAR(32) -->
    <changeSet id="v1.1.0-009-gov-gray-release" author="afg">
        <modifyDataType tableName="gov_gray_release" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="gov_gray_release" columnName="config_item_id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="gov_gray_release" columnName="environment_id" newDataType="VARCHAR(32)"/>
    </changeSet>

    <!-- gov_push_record: id BIGINT AUTO_INCREMENT -> VARCHAR(32), config_item_id BIGINT -> VARCHAR(32), add updated_at -->
    <changeSet id="v1.1.0-010-gov-push-record" author="afg">
        <modifyDataType tableName="gov_push_record" columnName="id" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="gov_push_record" columnName="config_item_id" newDataType="VARCHAR(32)"/>
        <addColumn tableName="gov_push_record">
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" remarks="更新时间"/>
        </addColumn>
    </changeSet>

    <!-- gov_subscription: id BIGINT AUTO_INCREMENT -> VARCHAR(32) -->
    <changeSet id="v1.1.0-011-gov-subscription" author="afg">
        <modifyDataType tableName="gov_subscription" columnName="id" newDataType="VARCHAR(32)"/>
    </changeSet>

</databaseChangeLog>
