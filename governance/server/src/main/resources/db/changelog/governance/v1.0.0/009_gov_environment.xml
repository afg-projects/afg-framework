<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="v1.0.0-009-gov-environment" author="afg">
        <createTable tableName="gov_environment" remarks="环境管理表">
            <column name="id" type="VARCHAR(32)">
                <constraints primaryKey="true" primaryKeyName="pk_gov_environment"/>
            </column>
            <column name="code" type="VARCHAR(50)" remarks="环境编码">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_gov_environment_code"/>
            </column>
            <column name="name" type="VARCHAR(100)" remarks="环境名称">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(500)" remarks="描述"/>
            <column name="sort" type="INT" remarks="排序" defaultValueNumeric="0"/>
            <column name="status" type="SMALLINT" remarks="状态" defaultValueNumeric="1"/>
            <column name="created_at" type="TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" remarks="更新时间"/>
            <column name="deleted" type="BOOLEAN" remarks="软删除" defaultValueBoolean="false"/>
        </createTable>

        <createIndex indexName="idx_gov_environment_code" tableName="gov_environment">
            <column name="code"/>
        </createIndex>

        <!-- 初始化默认环境 -->
        <insert tableName="gov_environment">
            <column name="id" value="1"/>
            <column name="code" value="dev"/>
            <column name="name" value="开发环境"/>
            <column name="description" value="开发测试环境"/>
            <column name="sort" valueNumeric="1"/>
            <column name="status" valueNumeric="1"/>
        </insert>
        <insert tableName="gov_environment">
            <column name="id" value="2"/>
            <column name="code" value="test"/>
            <column name="name" value="测试环境"/>
            <column name="description" value="功能测试环境"/>
            <column name="sort" valueNumeric="2"/>
            <column name="status" valueNumeric="1"/>
        </insert>
        <insert tableName="gov_environment">
            <column name="id" value="3"/>
            <column name="code" value="staging"/>
            <column name="name" value="预发布环境"/>
            <column name="description" value="预发布验证环境"/>
            <column name="sort" valueNumeric="3"/>
            <column name="status" valueNumeric="1"/>
        </insert>
        <insert tableName="gov_environment">
            <column name="id" value="4"/>
            <column name="code" value="prod"/>
            <column name="name" value="生产环境"/>
            <column name="description" value="正式生产环境"/>
            <column name="sort" valueNumeric="4"/>
            <column name="status" valueNumeric="1"/>
        </insert>
    </changeSet>

</databaseChangeLog>
