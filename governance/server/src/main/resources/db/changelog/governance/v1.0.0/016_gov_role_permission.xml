<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-016-gov-role-permission" author="afg">
        <createTable tableName="gov_role_permission" remarks="角色权限关联表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_gov_role_permission"/>
            </column>
            <column name="role_id" type="BIGINT" remarks="角色ID">
                <constraints nullable="false"/>
            </column>
            <column name="permission_id" type="BIGINT" remarks="权限ID">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="gov_role_permission" columnNames="role_id,permission_id"
                             constraintName="uk_gov_role_permission"/>

        <addForeignKeyConstraint baseTableName="gov_role_permission" baseColumnNames="role_id"
                                 constraintName="fk_gov_rp_role"
                                 referencedTableName="gov_role" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="gov_role_permission" baseColumnNames="permission_id"
                                 constraintName="fk_gov_rp_permission"
                                 referencedTableName="gov_permission" referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
