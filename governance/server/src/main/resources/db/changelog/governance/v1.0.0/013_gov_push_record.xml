<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="v1.0.0-013-gov-push-record" author="afg">
        <createTable tableName="gov_push_record" remarks="配置推送记录表">
            <column name="id" type="VARCHAR(32)">
                <constraints primaryKey="true" primaryKeyName="pk_gov_push_record"/>
            </column>
            <column name="config_item_id" type="VARCHAR(32)" remarks="配置项ID">
                <constraints nullable="false"/>
            </column>
            <column name="instance_id" type="VARCHAR(64)" remarks="实例ID">
                <constraints nullable="false"/>
            </column>
            <column name="push_status" type="SMALLINT" remarks="推送状态: 0-待推送, 1-已推送, 2-已确认, 3-推送失败" defaultValueNumeric="0"/>
            <column name="push_time" type="TIMESTAMP" remarks="推送时间"/>
            <column name="ack_time" type="TIMESTAMP" remarks="确认时间"/>
            <column name="error_message" type="TEXT" remarks="错误信息"/>
            <column name="created_at" type="TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" remarks="更新时间"/>
        </createTable>

        <createIndex indexName="idx_push_record_config_item" tableName="gov_push_record">
            <column name="config_item_id"/>
        </createIndex>

        <createIndex indexName="idx_push_record_status" tableName="gov_push_record">
            <column name="push_status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
