<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-008-gov-user-role" author="afg">
        <createTable tableName="gov_user_role" remarks="用户角色关联表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_gov_user_role"/>
            </column>
            <column name="user_id" type="BIGINT" remarks="用户ID">
                <constraints nullable="false"/>
            </column>
            <column name="role_id" type="BIGINT" remarks="角色ID">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(64)" remarks="租户ID"/>
            <column name="created_at" type="TIMESTAMP" remarks="创建时间"/>
        </createTable>

        <createIndex indexName="idx_user_role_user" tableName="gov_user_role">
            <column name="user_id"/>
        </createIndex>
        <createIndex indexName="idx_user_role_role" tableName="gov_user_role">
            <column name="role_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>