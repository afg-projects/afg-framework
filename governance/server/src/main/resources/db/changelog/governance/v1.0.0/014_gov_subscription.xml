<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd">

    <changeSet id="v1.0.0-014-gov-subscription" author="afg">
        <createTable tableName="gov_subscription" remarks="配置订阅关系表">
            <column name="id" type="VARCHAR(32)">
                <constraints primaryKey="true" primaryKeyName="pk_gov_subscription"/>
            </column>
            <column name="service_name" type="VARCHAR(100)" remarks="服务名称">
                <constraints nullable="false"/>
            </column>
            <column name="instance_id" type="VARCHAR(64)" remarks="实例ID">
                <constraints nullable="false"/>
            </column>
            <column name="subscribed_keys" type="TEXT" remarks="订阅的配置键列表(JSON数组)"/>
            <column name="connected_at" type="TIMESTAMP" remarks="连接时间"/>
            <column name="last_active" type="TIMESTAMP" remarks="最后活跃时间"/>
            <column name="status" type="SMALLINT" remarks="状态: 0-离线, 1-在线" defaultValueNumeric="1"/>
            <column name="created_at" type="TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" remarks="更新时间"/>
        </createTable>

        <createIndex indexName="idx_subscription_service_name" tableName="gov_subscription">
            <column name="service_name"/>
        </createIndex>

        <createIndex indexName="idx_subscription_instance_id" tableName="gov_subscription">
            <column name="instance_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
