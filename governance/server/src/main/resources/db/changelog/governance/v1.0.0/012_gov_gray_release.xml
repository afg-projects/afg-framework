<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="v1.0.0-012-gov-gray-release" author="afg">
        <createTable tableName="gov_gray_release" remarks="灰度发布表">
            <column name="id" type="VARCHAR(32)">
                <constraints primaryKey="true" primaryKeyName="pk_gov_gray_release"/>
            </column>
            <column name="config_item_id" type="VARCHAR(32)" remarks="配置项ID">
                <constraints nullable="false"/>
            </column>
            <column name="environment_id" type="VARCHAR(32)" remarks="环境ID">
                <constraints nullable="false"/>
            </column>
            <column name="new_value" type="TEXT" remarks="新值">
                <constraints nullable="false"/>
            </column>
            <column name="gray_instances" type="TEXT" remarks="灰度实例列表(JSON数组)"/>
            <column name="status" type="SMALLINT" remarks="状态: 0-待发布, 1-灰度中, 2-全量发布, 3-已回滚" defaultValueNumeric="0"/>
            <column name="created_by" type="VARCHAR(64)" remarks="创建人ID"/>
            <column name="created_at" type="TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" remarks="更新时间"/>
            <column name="deleted" type="BOOLEAN" remarks="软删除" defaultValueBoolean="false"/>
        </createTable>

        <createIndex indexName="idx_gray_release_config_item" tableName="gov_gray_release">
            <column name="config_item_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
