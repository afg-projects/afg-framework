<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-004-gov-config-history" author="afg">
        <createTable tableName="gov_config_history" remarks="配置变更历史表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_config_history"/>
            </column>
            <column name="item_id" type="BIGINT" remarks="配置项ID">
                <constraints nullable="false"/>
            </column>
            <column name="old_value" type="TEXT" remarks="旧值"/>
            <column name="new_value" type="TEXT" remarks="新值"/>
            <column name="change_type" type="VARCHAR(20)" remarks="变更类型">
                <constraints nullable="false"/>
            </column>
            <column name="reason" type="VARCHAR(500)" remarks="变更原因"/>
            <column name="operator_id" type="BIGINT" remarks="操作人ID"/>
            <column name="operator_name" type="VARCHAR(50)" remarks="操作人名称"/>
            <column name="tenant_id" type="VARCHAR(64)" remarks="租户ID"/>
            <column name="created_at" type="TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" remarks="更新时间"/>
        </createTable>

        <createIndex indexName="idx_config_history_item" tableName="gov_config_history">
            <column name="item_id"/>
        </createIndex>
        <createIndex indexName="idx_config_history_operator" tableName="gov_config_history">
            <column name="operator_id"/>
        </createIndex>
        <createIndex indexName="idx_config_history_time" tableName="gov_config_history">
            <column name="created_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>