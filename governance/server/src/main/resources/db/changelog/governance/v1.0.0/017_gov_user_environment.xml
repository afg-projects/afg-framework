<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-017-gov-user-environment" author="afg">
        <createTable tableName="gov_user_environment" remarks="用户环境关联表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_gov_user_environment"/>
            </column>
            <column name="user_id" type="BIGINT" remarks="用户ID">
                <constraints nullable="false"/>
            </column>
            <column name="environment_id" type="BIGINT" remarks="环境ID">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="gov_user_environment" columnNames="user_id,environment_id"
                             constraintName="uk_gov_user_environment"/>

        <addForeignKeyConstraint baseTableName="gov_user_environment" baseColumnNames="user_id"
                                 constraintName="fk_gov_ue_user"
                                 referencedTableName="gov_user" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="gov_user_environment" baseColumnNames="environment_id"
                                 constraintName="fk_gov_ue_environment"
                                 referencedTableName="gov_environment" referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
