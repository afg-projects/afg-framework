<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-005-sys-config-snapshot" author="afg">
        <createTable tableName="gov_config_snapshot" remarks="配置版本快照表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_config_snapshot"/>
            </column>
            <column name="name" type="VARCHAR(100)" remarks="快照名称">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(500)" remarks="描述"/>
            <column name="tag" type="VARCHAR(50)" remarks="标签"/>
            <column name="data" type="LONGTEXT" remarks="快照数据（JSON）"/>
            <column name="group_id" type="BIGINT" remarks="分组ID"/>
            <column name="creator_id" type="BIGINT" remarks="创建人ID"/>
            <column name="creator_name" type="VARCHAR(50)" remarks="创建人名称"/>
            <column name="tenant_id" type="VARCHAR(64)" remarks="租户ID"/>
            <column name="created_at" type="TIMESTAMP" remarks="创建时间"/>
        </createTable>

        <createIndex indexName="idx_config_snapshot_tag" tableName="gov_config_snapshot">
            <column name="tag"/>
        </createIndex>
        <createIndex indexName="idx_config_snapshot_group" tableName="gov_config_snapshot">
            <column name="group_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>