<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-006-sys-user" author="afg">
        <createTable tableName="gov_user" remarks="治理中心用户表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_gov_user"/>
            </column>
            <column name="username" type="VARCHAR(50)" remarks="用户名">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_user_username"/>
            </column>
            <column name="password" type="VARCHAR(100)" remarks="密码">
                <constraints nullable="false"/>
            </column>
            <column name="real_name" type="VARCHAR(50)" remarks="真实姓名"/>
            <column name="mobile" type="VARCHAR(20)" remarks="手机号"/>
            <column name="email" type="VARCHAR(100)" remarks="邮箱"/>
            <column name="avatar" type="VARCHAR(200)" remarks="头像"/>
            <column name="user_type" type="VARCHAR(20)" remarks="用户类型" defaultValue="user"/>
            <column name="status" type="INT" remarks="状态" defaultValueNumeric="1"/>
            <column name="tenant_id" type="VARCHAR(64)" remarks="租户ID"/>
            <column name="deleted" type="BOOLEAN" remarks="软删除" defaultValueBoolean="false"/>
            <column name="version" type="BIGINT" remarks="版本号" defaultValueNumeric="0"/>
            <column name="created_at" type="TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" remarks="更新时间"/>
            <column name="create_by" type="VARCHAR(64)" remarks="创建人ID"/>
            <column name="update_by" type="VARCHAR(64)" remarks="更新人ID"/>
        </createTable>

        <createIndex indexName="idx_user_username" tableName="gov_user">
            <column name="username"/>
        </createIndex>
        <createIndex indexName="idx_user_mobile" tableName="gov_user">
            <column name="mobile"/>
        </createIndex>
        <createIndex indexName="idx_user_email" tableName="gov_user">
            <column name="email"/>
        </createIndex>

        <!-- 初始化管理员账户 (密码: admin123) -->
        <insert tableName="gov_user">
            <column name="username" value="admin"/>
            <column name="password" value="$2a$10$UYsGZIdfbTCNENYUsBmLD.9ZOOCXqsRPDxpkXrjT5sI2HFN6k3WPK"/>
            <column name="real_name" value="系统管理员"/>
            <column name="user_type" value="admin"/>
            <column name="status" valueNumeric="1"/>
        </insert>
    </changeSet>

</databaseChangeLog>