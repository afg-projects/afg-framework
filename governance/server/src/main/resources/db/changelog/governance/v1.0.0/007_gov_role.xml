<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="v1.0.0-007-gov-role" author="afg">
        <createTable tableName="gov_role" remarks="治理中心角色表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_gov_role"/>
            </column>
            <column name="code" type="VARCHAR(50)" remarks="角色编码">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_role_code"/>
            </column>
            <column name="name" type="VARCHAR(50)" remarks="角色名称">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(200)" remarks="描述"/>
            <column name="status" type="INT" remarks="状态" defaultValueNumeric="1"/>
            <column name="tenant_id" type="VARCHAR(64)" remarks="租户ID"/>
            <column name="deleted" type="BOOLEAN" remarks="软删除" defaultValueBoolean="false"/>
            <column name="version" type="BIGINT" remarks="版本号" defaultValueNumeric="0"/>
            <column name="created_at" type="TIMESTAMP" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP" remarks="更新时间"/>
            <column name="create_by" type="VARCHAR(64)" remarks="创建人ID"/>
            <column name="update_by" type="VARCHAR(64)" remarks="更新人ID"/>
        </createTable>

        <createIndex indexName="idx_role_code" tableName="gov_role">
            <column name="code"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>