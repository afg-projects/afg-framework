<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd">
    <changeSet id="v1.0.0-008-test-encrypted-user" author="afg">
        <createTable tableName="test_encrypted_user" remarks="测试加密用户表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_test_encrypted_user"/>
            </column>
            <column name="username" type="VARCHAR(50)" remarks="用户名"/>
            <column name="phone" type="VARCHAR(512)" remarks="加密手机号"/>
            <column name="phone_hash" type="VARCHAR(128)" remarks="手机号盲索引"/>
            <column name="status" type="INT" defaultValueNumeric="1" remarks="状态"/>
            <column name="created_at" type="TIMESTAMP WITHOUT TIME ZONE" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP WITHOUT TIME ZONE" remarks="更新时间"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
