<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="v1.0.0-006-test-order-item" author="afg">
        <createTable tableName="test_order_item" remarks="测试订单项表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_test_order_item"/>
            </column>
            <column name="order_id" type="BIGINT" remarks="订单ID"/>
            <column name="product_name" type="VARCHAR(100)" remarks="产品名称"/>
            <column name="price" type="DECIMAL(10,2)" remarks="价格"/>
            <column name="quantity" type="INT" remarks="数量"/>
            <column name="created_at" type="TIMESTAMP WITHOUT TIME ZONE" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP WITHOUT TIME ZONE" remarks="更新时间"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
