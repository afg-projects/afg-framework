<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="v1.0.0-002-test-soft-delete-item" author="afg">
        <createTable tableName="test_soft_delete_item" remarks="测试软删除表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_test_soft_delete_item"/>
            </column>
            <column name="name" type="VARCHAR(50)" remarks="名称"/>
            <column name="quantity" type="INT" remarks="数量"/>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false" remarks="是否删除"/>
            <column name="created_at" type="TIMESTAMP WITHOUT TIME ZONE" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP WITHOUT TIME ZONE" remarks="更新时间"/>
        </createTable>
    </changeSet>
</databaseChangeLog>