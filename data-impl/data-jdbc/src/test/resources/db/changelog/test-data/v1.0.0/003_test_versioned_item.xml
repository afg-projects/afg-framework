<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd">
    <changeSet id="v1.0.0-003-test-versioned-item" author="afg">
        <createTable tableName="test_versioned_item" remarks="测试乐观锁表">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_test_versioned_item"/>
            </column>
            <column name="name" type="VARCHAR(50)" remarks="名称"/>
            <column name="stock" type="INT" remarks="库存"/>
            <column name="version" type="INT" defaultValueNumeric="0" remarks="版本号"/>
            <column name="created_at" type="TIMESTAMP WITHOUT TIME ZONE" remarks="创建时间"/>
            <column name="updated_at" type="TIMESTAMP WITHOUT TIME ZONE" remarks="更新时间"/>
        </createTable>
    </changeSet>
</databaseChangeLog>